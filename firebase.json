{
  "firestore": {
    "rules": "reference/web-scoring/firestore.rules"
  },
  "storage": {
    "rules": "reference/web-scoring/storage.rules"
  },
  "hosting": {
    "public": "reference/web-scoring",
    "cleanUrls": true,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "server.js",
      "package.json",
      "package-lock.json"
    ],
    "rewrites": [
      { "source": "/", "destination": "/scoring-controller.html" }
    ]
  }
}
