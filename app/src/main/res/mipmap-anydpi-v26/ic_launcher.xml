<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive launcher icon (API 26+). Solid dark background fills the whole mask so the
     launcher can never add black corners/borders; the transparent "A" mark is the foreground,
     inset into the safe zone. Fixes the "weird black borders around the edge" on the old
     legacy-PNG-only icon. -->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background" />
    <foreground android:drawable="@mipmap/ic_launcher_foreground" />
</adaptive-icon>
