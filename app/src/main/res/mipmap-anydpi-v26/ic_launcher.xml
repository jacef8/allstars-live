<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive launcher icon (API 26+). Full-bleed glossy blue sunburst background reaches every
     edge so the launcher mask can't add a black frame; the transparent "A" mark is the
     foreground, inset into the safe zone. Fixes the "weird black borders around the edge" the
     old legacy-PNG icon showed (it had rounded corners + a dark frame baked in, then got masked
     a second time). -->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@mipmap/ic_launcher_bg_rays" />
    <foreground android:drawable="@mipmap/ic_launcher_foreground" />
</adaptive-icon>
