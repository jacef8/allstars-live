<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Compose drives the UI; this base theme just provides a no-action-bar,
         dark, fullscreen-friendly shell for the broadcast scorer. -->
    <style name="Theme.AllStarsLive" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_window</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
        <!-- Android 12+ system splash (it ignores windowBackground): the star emblem on navy.
             Older devices fall back to @drawable/splash_window above. -->
        <item name="android:windowSplashScreenBackground">#11203A</item>
        <item name="android:windowSplashScreenAnimatedIcon">@mipmap/splash_icon</item>
        <!-- Match the icon's circular backdrop to the navy background. Without this, Samsung/One UI
             (and some other OEMs) fill the circle behind the icon with a default light colour, which
             reads as a white "box" around the transparent star. Navy = the circle blends away. -->
        <item name="android:windowSplashScreenIconBackgroundColor">#11203A</item>
    </style>
</resources>
