<?xml version="1.0" encoding="utf-8"?>
<!-- System launch splash: A logo centered on the dark app background (no white flash). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@android:color/black" />
    <item android:gravity="center" android:width="150dp" android:height="150dp">
        <bitmap android:src="@drawable/splash_logo" android:gravity="center" />
    </item>
</layer-list>
