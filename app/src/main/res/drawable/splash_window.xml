<?xml version="1.0" encoding="utf-8"?>
<!-- System launch splash: the A logo big over the blue turf (matches the in-app splash). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <bitmap android:src="@drawable/splash_turf" android:gravity="fill" />
    </item>
    <item>
        <color android:color="#66070B13" />
    </item>
    <item android:gravity="center" android:width="320dp" android:height="320dp">
        <bitmap android:src="@drawable/splash_logo" android:gravity="center" />
    </item>
</layer-list>
