rules_version = '2';
// All-Stars Live — Firestore security rules.
// Paste into: Firebase console → Build → Firestore Database → Rules → Publish.
//
// A team is owned by ownerUid. The owner can do anything to it. Authorized scorers
// (their email is in the team's `scorers` list) may update game/roster data but may NOT
// change the owner or the scorers list. Anyone signed-in who is owner or a listed scorer
// can read the team. Nobody else can read or write it.
service cloud.firestore {
  match /databases/{database}/documents {

    match /teams/{teamId} {
      function isOwner()  { return request.auth != null && resource.data.ownerUid == request.auth.uid; }
      function isScorer() { return request.auth != null && resource.data.scorers is list
                              && (request.auth.token.email in resource.data.scorers); }

      allow read: if isOwner() || isScorer();

      // Create: must stamp yourself as the owner.
      allow create: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;

      // Update:
      //  • Owner = anything.
      //  • Scorer = anything EXCEPT changing owner or the scorers list.
      //  • Self-join (texted invite): any signed-in user may append ONLY their own email to
      //    `scorers` (adds exactly one entry, their email, which wasn't there before) and
      //    touch nothing else. The owner can remove anyone.
      allow update: if isOwner()
        || (
          isScorer() &&
          request.resource.data.ownerUid == resource.data.ownerUid &&
          request.resource.data.scorers == resource.data.scorers
        )
        || (
          request.auth != null &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['scorers', 'updatedAt']) &&
          !(request.auth.token.email in resource.data.scorers) &&
          (request.auth.token.email in request.resource.data.scorers) &&
          request.resource.data.scorers.size() == resource.data.scorers.size() + 1
        );

      allow delete: if isOwner();
    }

    // (Live game docs / shared games will get their own rules in a later phase.)
  }
}
